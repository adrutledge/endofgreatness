[gd_scene load_steps=2 format=3 uid="uid://hud"]

[ext_resource type="Script" path="res://src/ui/campaign/HUD.gd" id="1"]

[node name="HUD" type="CanvasLayer"]
script = ExtResource("1")
layer = 3

[node name="TopBar" type="HBoxContainer" parent="."]

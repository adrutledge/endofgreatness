[gd_scene load_steps=2 format=3 uid="uid://hud"]

[ext_resource type="Script" path="res://src/ui/campaign/HUD.gd" id="1"]

[node name="HUD" type="CanvasLayer"]
script = ExtResource("1")
layer = 3

[node name="Margin" type="MarginContainer" parent="."]
anchors_preset = 0
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_constants/margin_left = 6
theme_override_constants/margin_top = 6
theme_override_constants/margin_right = 6
theme_override_constants/margin_bottom = 6
mouse_filter = 2

[node name="TopBar" type="HBoxContainer" parent="Margin"]
size_flags_horizontal = 3
mouse_filter = 2

[node name="Finances" type="VBoxContainer" parent="Margin/TopBar"]
mouse_filter = 1

[node name="BalanceLabel" type="Label" parent="Margin/TopBar/Finances"]
unique_name_in_owner = true
text = "C-Bills: —"
theme_override_font_sizes/font_size = 12
add_theme_color_override("font_color", Color(0.8, 1.0, 0.6))

[node name="BillsLabel" type="Label" parent="Margin/TopBar/Finances"]
unique_name_in_owner = true
text = "Daily Burn: —"
theme_override_font_sizes/font_size = 11
add_theme_color_override("font_color", Color(0.7, 0.8, 0.9))


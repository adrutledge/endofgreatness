anchor_top = 0.0
anchor_bottom = 0.0
margin_bottom = 28.0
theme_override_constants/margin_left = 4
theme_override_constants/margin_right = 4

[node name="MenuButton" type="MenuButton" parent="TopBar"]
text = "☰"
theme_override_font_sizes/font_size = 14
flat = true

[node name="Finances" type="VBoxContainer" parent="TopBar"]

[node name="BalanceLabel" type="Label" parent="TopBar/Finances"]
